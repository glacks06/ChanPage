---
import Header from '../components/header.astro';
import '../styles/main.scss';

const { hasSidebar = true } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
    <head>
        <title>Chan's Trace</title>
        <meta charset="UTF-8" />
        <link rel="stylesheet" as="style" crossorigin href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />
    </head>
    <body>
        <Header />
        <div class={hasSidebar ? 'main-wrapper-with-sidebar' : 'main-wrapper-without-sidebar'}>
            
            {hasSidebar && (
                <aside class="sidebar-area">
                    <slot name="sidebar" />
                </aside>
            )}

            <main class={hasSidebar ? 'content-with-sidebar' : 'content-full'}>
                <slot />
            </main>
            
        </div>
    </body>
</html>

<style lang="scss">
    .main-wrapper-with-sidebar {display: flex;}

</style>